# 🌐 Frontend Environment Variables
# Copy this file to .env.local and update the values

# ============================================================================
# 🔐 SESSION CONFIGURATION (Required for NextAuth.js)
# ============================================================================
# Session secret for Next.js sessions (minimum 32 characters)
# MUST be set as GitHub repository secret: SESSION_SECRET
SESSION_SECRET=your_session_secret_here_minimum_32_characters

# ============================================================================
# 🌐 API CONFIGURATION
# ============================================================================
# Backend API URL (public - exposed to client)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Frontend app URL (public - exposed to client)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# 📁 UPLOAD CONFIGURATION
# ============================================================================
# UploadThing token for file uploads
UPLOADTHING_TOKEN=your_uploadthing_token_here

# ============================================================================
# 🌤️ EXTERNAL APIS
# ============================================================================
# OpenWeather API key for weather data
OPENWEATHERAPIKEY=your_openweather_api_key_here

# ============================================================================
# 🚀 BUILD CONFIGURATION
# ============================================================================
# Set to true in CI/CD to skip environment validation
SKIP_ENV_VALIDATION=false

# Node environment
NODE_ENV=development
